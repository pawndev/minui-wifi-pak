#!/bin/sh
set -x
BIN_DIR="$(dirname "$0")"
PAK_DIR="$(dirname "$BIN_DIR")"
PAK_NAME="$(basename "$PAK_DIR")"
PAK_NAME="${PAK_NAME%.*}"

rm -f "$LOGS_PATH/$PAK_NAME.on-boot.txt"
exec >>"$LOGS_PATH/$PAK_NAME.on-boot.txt"
exec 2>&1

echo "$0" "$@"
cd "$PAK_DIR" || exit 1

main() {
    {
        for _i in $(seq 1 60); do
            [ -f /tmp/minui_exec ] && break
            sleep 1
        done
        unset _i

        if "$BIN_DIR/wifi-enabled" 2>/dev/null; then
            echo "WiFi already active, skipping initialization"
            exit 0
        fi
        "$BIN_DIR/service-on" &
    } &
}

main "$@"
